                    <TextBlock Text="Ambient" FontWeight="SemiBold" FontSize="13" Margin="0,10,0,3"/>
                    <TextBlock Text="Shimmer with a relaxed, understated vibe."
                               FontSize="10" Foreground="#888" Margin="0,0,0,8"/>

                    <WrapPanel Margin="0,0,0,10">

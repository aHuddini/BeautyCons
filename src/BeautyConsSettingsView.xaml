<UserControl x:Class="BeautyCons.BeautyConsSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:glow="clr-namespace:BeautyCons.IconGlow"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600">
    <TabControl>
        <!-- General Tab -->
        <TabItem Header="General">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="20">
                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="General Settings" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="Reset to Defaults" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Click="ResetGeneralTab_Click" Padding="8,3" FontSize="11"/>
                    </Grid>

                    <CheckBox Content="Enable Plugin"
                              IsChecked="{Binding Settings.EnablePlugin}"
                              Margin="0,5"/>
                    <TextBlock Text="When enabled, BeautyCons will enhance your game library icons"
                               FontSize="11"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               Margin="20,0,0,10"/>

                    <CheckBox Content="Enable Debug Logging"
                              IsChecked="{Binding Settings.EnableDebugLogging}"
                              Margin="0,5"/>
                    <TextBlock Text="Enables verbose logging for troubleshooting issues"
                               FontSize="11"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               Margin="20,0,0,10"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Icon Glow Tab -->
        <TabItem Header="Icon Glow">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="20">
                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="Icon Glow Settings" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="Reset to Defaults" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Click="ResetIconGlowTab_Click" Padding="8,3" FontSize="11"/>
                    </Grid>

                    <CheckBox Content="Enable Icon Glow"
                              IsChecked="{Binding Settings.EnableIconGlow}"
                              Margin="0,5"/>
                    <TextBlock Text="Applies a colored glow effect around the selected game's icon"
                               FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="20,0,0,10"/>

                    <TextBlock Text="Glow Style" FontWeight="SemiBold" Margin="0,10,0,5"/>
                    <ComboBox SelectedValue="{Binding Settings.IconGlowStyle}"
                              SelectedValuePath="Tag"
                              Width="200" HorizontalAlignment="Left">
                        <ComboBoxItem Content="Neon — Bold multi-layer additive glow" Tag="{x:Static glow:GlowStyle.Neon}"/>
                        <ComboBoxItem Content="Soft — Wide dreamy single-layer glow" Tag="{x:Static glow:GlowStyle.Soft}"/>
                        <ComboBoxItem Content="Sharp — Tight edge highlight" Tag="{x:Static glow:GlowStyle.Sharp}"/>
                        <ComboBoxItem Content="Bloom — Overexposed bright center" Tag="{x:Static glow:GlowStyle.Bloom}"/>
                        <ComboBoxItem Content="Halo — Soft ring around icon" Tag="{x:Static glow:GlowStyle.Halo}"/>
                        <ComboBoxItem Content="Diamond — Diamond-shaped glow" Tag="{x:Static glow:GlowStyle.Diamond}"/>
                        <ComboBoxItem Content="Cross — Cross-shaped glow" Tag="{x:Static glow:GlowStyle.Cross}"/>
                        <ComboBoxItem Content="Star — 4-pointed star burst" Tag="{x:Static glow:GlowStyle.Star}"/>
                    </ComboBox>

                    <TextBlock Text="Glow Size" FontWeight="SemiBold" Margin="0,15,0,5"/>
                    <DockPanel Margin="0,0,0,5">
                        <TextBlock DockPanel.Dock="Right" Width="30" TextAlignment="Center"
                                   Text="{Binding Settings.IconGlowSize, StringFormat={}{0:F1}}"/>
                        <Slider Minimum="2.0" Maximum="12.0" TickFrequency="0.5" IsSnapToTickEnabled="True"
                                Value="{Binding Settings.IconGlowSize}"/>
                    </DockPanel>

                    <TextBlock Text="Glow Intensity" FontWeight="SemiBold" Margin="0,10,0,5"/>
                    <DockPanel Margin="0,0,0,5">
                        <TextBlock DockPanel.Dock="Right" Width="30" TextAlignment="Center"
                                   Text="{Binding Settings.IconGlowIntensity, StringFormat={}{0:F1}}"/>
                        <Slider Minimum="0.5" Maximum="3.0" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                Value="{Binding Settings.IconGlowIntensity}"/>
                    </DockPanel>

                    <CheckBox Content="Enable Spin Rotation"
                              IsChecked="{Binding Settings.EnableIconGlowSpin}"
                              Margin="0,15,0,5"/>
                    <TextBlock Text="Rotates the glow effect around the icon"
                               FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="20,0,0,5"/>

                    <StackPanel Margin="20,0,0,0" IsEnabled="{Binding Settings.EnableIconGlowSpin}">
                        <TextBlock Text="Spin Speed (seconds per rotation)" FontWeight="SemiBold" Margin="0,5,0,5"/>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock DockPanel.Dock="Right" Width="30" TextAlignment="Center"
                                       Text="{Binding Settings.IconGlowSpinSpeed, StringFormat={}{0:F0}}"/>
                            <Slider Minimum="5" Maximum="60" TickFrequency="1" IsSnapToTickEnabled="True"
                                    Value="{Binding Settings.IconGlowSpinSpeed}"/>
                        </DockPanel>
                    </StackPanel>

                    <CheckBox Content="Enable Pulse"
                              IsChecked="{Binding Settings.EnablePulse}"
                              Margin="0,15,0,5"/>
                    <TextBlock Text="Glow breathes in and out on a smooth cycle"
                               FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="20,0,0,5"/>

                    <StackPanel Margin="20,0,0,0" IsEnabled="{Binding Settings.EnablePulse}">
                        <TextBlock Text="Pulse Speed (seconds per cycle)" FontWeight="SemiBold" Margin="0,5,0,5"/>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock DockPanel.Dock="Right" Width="30" TextAlignment="Center"
                                       Text="{Binding Settings.PulseSpeed, StringFormat={}{0:F1}}"/>
                            <Slider Minimum="1.0" Maximum="10.0" TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    Value="{Binding Settings.PulseSpeed}"/>
                        </DockPanel>
                        <TextBlock Text="Minimum Opacity" FontWeight="SemiBold" Margin="0,5,0,5"/>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock DockPanel.Dock="Right" Width="35" TextAlignment="Center"
                                       Text="{Binding Settings.PulseMinOpacity, StringFormat={}{0:P0}}"/>
                            <Slider Minimum="0.0" Maximum="0.8" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    Value="{Binding Settings.PulseMinOpacity}"/>
                        </DockPanel>
                    </StackPanel>

                    <CheckBox Content="Enable Color Cycle"
                              IsChecked="{Binding Settings.EnableColorCycle}"
                              Margin="0,15,0,5"/>
                    <TextBlock Text="Gradually shifts glow colors over time"
                               FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="20,0,0,5"/>

                    <StackPanel Margin="20,0,0,0" IsEnabled="{Binding Settings.EnableColorCycle}">
                        <TextBlock Text="Cycle Duration (seconds for full rotation)" FontWeight="SemiBold" Margin="0,5,0,5"/>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock DockPanel.Dock="Right" Width="30" TextAlignment="Center"
                                       Text="{Binding Settings.ColorCycleSpeed, StringFormat={}{0:F0}}"/>
                            <Slider Minimum="4" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True"
                                    Value="{Binding Settings.ColorCycleSpeed}"/>
                        </DockPanel>
                    </StackPanel>

                    <CheckBox Content="Enable Sparkles"
                              IsChecked="{Binding Settings.EnableSparkles}"
                              Margin="0,15,0,5"/>
                    <TextBlock Text="Small bright dots appear and fade around the glow"
                               FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="20,0,0,5"/>

                    <StackPanel Margin="20,0,0,0" IsEnabled="{Binding Settings.EnableSparkles}">
                        <TextBlock Text="Sparkle Count" FontWeight="SemiBold" Margin="0,5,0,5"/>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock DockPanel.Dock="Right" Width="30" TextAlignment="Center"
                                       Text="{Binding Settings.SparkleCount}"/>
                            <Slider Minimum="4" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True"
                                    Value="{Binding Settings.SparkleCount}"/>
                        </DockPanel>
                        <TextBlock Text="Sparkle Speed" FontWeight="SemiBold" Margin="0,5,0,5"/>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock DockPanel.Dock="Right" Width="30" TextAlignment="Center"
                                       Text="{Binding Settings.SparkleSpeed, StringFormat={}{0:F1}}"/>
                            <Slider Minimum="0.3" Maximum="3.0" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                    Value="{Binding Settings.SparkleSpeed}"/>
                        </DockPanel>
                    </StackPanel>

                    <TextBlock Text="Icon Effects" FontSize="16" FontWeight="Bold" Margin="0,20,0,10"/>

                    <CheckBox Content="Enable Shine Sweep"
                              IsChecked="{Binding Settings.EnableShineSweep}"
                              Margin="0,15,0,5"/>
                    <TextBlock Text="A diagonal light sweep moves across the icon like a glossy surface. Works best with square icons."
                               FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="20,0,0,5"/>

                    <StackPanel Margin="20,0,0,0" IsEnabled="{Binding Settings.EnableShineSweep}">
                        <TextBlock Text="Sweep Speed (seconds per sweep)" FontWeight="SemiBold" Margin="0,5,0,5"/>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock DockPanel.Dock="Right" Width="30" TextAlignment="Center"
                                       Text="{Binding Settings.ShineSweepSpeed, StringFormat={}{0:F1}}"/>
                            <Slider Minimum="1.0" Maximum="8.0" TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    Value="{Binding Settings.ShineSweepSpeed}"/>
                        </DockPanel>
                    </StackPanel>

                    <CheckBox Content="Enable Shimmer"
                              IsChecked="{Binding Settings.EnableShimmer}"
                              Margin="0,15,0,5"/>
                    <TextBlock Text="Shine sweep with metallic luster — a glossy light bar glides across the icon with directional lighting."
                               FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="20,0,0,5"/>

                    <StackPanel Margin="20,0,0,0" IsEnabled="{Binding Settings.EnableShimmer}">
                        <CheckBox Content="Include Tilt"
                                  IsChecked="{Binding Settings.EnableTilt}"
                                  Margin="0,5,0,3"/>
                        <TextBlock Text="Adds a subtle 3D tilt rocking motion synced with the shimmer cycle. Works best with smaller or circular icons."
                                   FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="20,0,0,8"/>
                        <TextBlock Text="Shine Style" FontWeight="SemiBold" Margin="0,5,0,5"/>
                        <ComboBox SelectedValue="{Binding Settings.ShimmerShineStyle}"
                                  SelectedValuePath="Tag"
                                  Width="220" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <ComboBoxItem Content="White — Clean specular highlight" Tag="{x:Static glow:ShineStyle.White}"/>
                            <ComboBoxItem Content="Gold — Warm legendary rarity shine" Tag="{x:Static glow:ShineStyle.Gold}"/>
                            <ComboBoxItem Content="Holographic — Rainbow iridescence" Tag="{x:Static glow:ShineStyle.Holographic}"/>
                            <ComboBoxItem Content="Platinum — Cool silver-blue metallic" Tag="{x:Static glow:ShineStyle.Platinum}"/>
                            <ComboBoxItem Content="Crimson — Deep red/orange epic shine" Tag="{x:Static glow:ShineStyle.Crimson}"/>
                            <ComboBoxItem Content="Icon Colors — Uses glow colors" Tag="{x:Static glow:ShineStyle.IconColors}"/>
                        </ComboBox>
                        <TextBlock Text="Shimmer Speed (seconds per cycle)" FontWeight="SemiBold" Margin="0,5,0,5"/>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock DockPanel.Dock="Right" Width="30" TextAlignment="Center"
                                       Text="{Binding Settings.ShimmerSpeed, StringFormat={}{0:F1}}"/>
                            <Slider Minimum="1.0" Maximum="10.0" TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    Value="{Binding Settings.ShimmerSpeed}"/>
                        </DockPanel>
                        <TextBlock Text="Shimmer Intensity" FontWeight="SemiBold" Margin="0,5,0,5"/>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock DockPanel.Dock="Right" Width="35" TextAlignment="Center"
                                       Text="{Binding Settings.ShimmerOpacity, StringFormat={}{0:P0}}"/>
                            <Slider Minimum="0.1" Maximum="0.9" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    Value="{Binding Settings.ShimmerOpacity}"/>
                        </DockPanel>
                        <TextBlock Text="Pause Between Shimmers (seconds)" FontWeight="SemiBold" Margin="0,5,0,3"/>
                        <TextBlock Text="Random delay between shine sweeps"
                                   FontSize="11" Foreground="Gray" Margin="0,0,0,5"/>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock DockPanel.Dock="Left" Text="Min:" Width="30" VerticalAlignment="Center"/>
                            <TextBlock DockPanel.Dock="Right" Width="30" TextAlignment="Center"
                                       Text="{Binding Settings.ShimmerPauseMin, StringFormat={}{0:F1}}"/>
                            <Slider Minimum="0.0" Maximum="8.0" TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    Value="{Binding Settings.ShimmerPauseMin}"/>
                        </DockPanel>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock DockPanel.Dock="Left" Text="Max:" Width="30" VerticalAlignment="Center"/>
                            <TextBlock DockPanel.Dock="Right" Width="30" TextAlignment="Center"
                                       Text="{Binding Settings.ShimmerPauseMax, StringFormat={}{0:F1}}"/>
                            <Slider Minimum="0.0" Maximum="12.0" TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    Value="{Binding Settings.ShimmerPauseMax}"/>
                        </DockPanel>
                    </StackPanel>

                    <CheckBox Content="Enable Color Shimmer"
                              IsChecked="{Binding Settings.EnableColorShimmer}"
                              Margin="0,15,0,5"/>
                    <TextBlock Text="Same tilt+shine as Shimmer, but the light sweep uses the icon's glow colors instead of white. Overrides standard Shimmer if both are enabled."
                               FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="20,0,0,5"/>

                    <StackPanel Margin="20,0,0,0" IsEnabled="{Binding Settings.EnableColorShimmer}">
                        <TextBlock Text="Sweep Speed (seconds per cycle)" FontWeight="SemiBold" Margin="0,5,0,5"/>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock DockPanel.Dock="Right" Width="30" TextAlignment="Center"
                                       Text="{Binding Settings.ColorShimmerSpeed, StringFormat={}{0:F1}}"/>
                            <Slider Minimum="1.0" Maximum="10.0" TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    Value="{Binding Settings.ColorShimmerSpeed}"/>
                        </DockPanel>
                        <TextBlock Text="Color Shimmer Intensity" FontWeight="SemiBold" Margin="0,5,0,5"/>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock DockPanel.Dock="Right" Width="35" TextAlignment="Center"
                                       Text="{Binding Settings.ColorShimmerOpacity, StringFormat={}{0:P0}}"/>
                            <Slider Minimum="0.1" Maximum="0.9" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    Value="{Binding Settings.ColorShimmerOpacity}"/>
                        </DockPanel>
                    </StackPanel>

                    <TextBlock Text="Color Preset" FontWeight="SemiBold" Margin="0,15,0,5"/>
                    <ComboBox SelectedValue="{Binding Settings.ColorPreset}"
                              SelectedValuePath="Tag"
                              Width="200" HorizontalAlignment="Left">
                        <ComboBoxItem Content="Auto (from icon)" Tag="{x:Static glow:ColorPreset.Auto}"/>
                        <ComboBoxItem Content="Hot Pink" Tag="{x:Static glow:ColorPreset.HotPink}"/>
                        <ComboBoxItem Content="Ocean" Tag="{x:Static glow:ColorPreset.Ocean}"/>
                        <ComboBoxItem Content="Sunset" Tag="{x:Static glow:ColorPreset.Sunset}"/>
                        <ComboBoxItem Content="Neon Green" Tag="{x:Static glow:ColorPreset.NeonGreen}"/>
                        <ComboBoxItem Content="Purple Haze" Tag="{x:Static glow:ColorPreset.PurpleHaze}"/>
                        <ComboBoxItem Content="Ice" Tag="{x:Static glow:ColorPreset.Ice}"/>
                        <ComboBoxItem Content="Fire" Tag="{x:Static glow:ColorPreset.Fire}"/>
                        <ComboBoxItem Content="Gold" Tag="{x:Static glow:ColorPreset.Gold}"/>
                        <ComboBoxItem Content="Vampire" Tag="{x:Static glow:ColorPreset.Vampire}"/>
                        <ComboBoxItem Content="Mint" Tag="{x:Static glow:ColorPreset.Mint}"/>
                        <ComboBoxItem Content="Synthwave" Tag="{x:Static glow:ColorPreset.Synthwave}"/>
                        <ComboBoxItem Content="Retrowave" Tag="{x:Static glow:ColorPreset.Retrowave}"/>
                        <ComboBoxItem Content="Vaporwave" Tag="{x:Static glow:ColorPreset.Vaporwave}"/>
                        <ComboBoxItem Content="Cyberpunk" Tag="{x:Static glow:ColorPreset.Cyberpunk}"/>
                        <ComboBoxItem Content="Aurora" Tag="{x:Static glow:ColorPreset.Aurora}"/>
                        <ComboBoxItem Content="Electric" Tag="{x:Static glow:ColorPreset.Electric}"/>
                        <ComboBoxItem Content="Plasma" Tag="{x:Static glow:ColorPreset.Plasma}"/>
                        <ComboBoxItem Content="Toxic" Tag="{x:Static glow:ColorPreset.Toxic}"/>
                        <ComboBoxItem Content="Hologram" Tag="{x:Static glow:ColorPreset.Hologram}"/>
                        <ComboBoxItem Content="Dreamscape" Tag="{x:Static glow:ColorPreset.Dreamscape}"/>
                        <ComboBoxItem Content="Monochrome" Tag="{x:Static glow:ColorPreset.Monochrome}"/>
                        <ComboBoxItem Content="Custom..." Tag="{x:Static glow:ColorPreset.Custom}"/>
                    </ComboBox>

                    <StackPanel Margin="20,5,0,0" x:Name="CustomColorPanel">
                        <DockPanel Margin="0,5">
                            <TextBlock Text="Primary Color:" Width="110" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding Settings.CustomColor1, UpdateSourceTrigger=PropertyChanged}"
                                     Width="100" HorizontalAlignment="Left"/>
                        </DockPanel>
                        <DockPanel Margin="0,5">
                            <TextBlock Text="Secondary Color:" Width="110" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding Settings.CustomColor2, UpdateSourceTrigger=PropertyChanged}"
                                     Width="100" HorizontalAlignment="Left"/>
                        </DockPanel>
                        <TextBlock Text="Enter colors as hex values (e.g. #6495ED)"
                                   FontSize="11" Foreground="Gray" Margin="0,2,0,0"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <!-- Preview Tab -->
        <TabItem Header="Preview">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,15,20,10">
                    <TextBlock Text="Glow Preview" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Shows how your current glow settings look on example game icons"
                               FontSize="11" Foreground="Gray" Margin="0,3,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" Margin="20,0,20,10"
                        CornerRadius="6" BorderThickness="1"
                        BorderBrush="#333344">
                    <Grid x:Name="PreviewContainer"
                          Background="#1A1A2E"/>
                </Border>

                <Button Grid.Row="2" Content="Refresh Preview"
                        Click="RefreshPreview_Click"
                        HorizontalAlignment="Center"
                        Padding="20,6" Margin="0,0,0,15" FontSize="12"/>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>

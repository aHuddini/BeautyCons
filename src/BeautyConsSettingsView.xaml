        </TabItem>

        <!-- Disclaimer Tab -->
        <TabItem Header="About">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="20">
                    <TextBlock Text="About BeautyCons" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Text="BeautyCons adds visual effects to game icons in Playnite's detail view by injecting custom WPF elements into the visual tree at runtime."
                               FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>

                    <TextBlock Text="How It Works" FontWeight="SemiBold" FontSize="13" Margin="0,5,0,5"/>
                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#CCC" Margin="0,0,0,15">
                        BeautyCons discovers the game icon element (PART_ImageIcon) in Playnite's visual tree, wraps it in a Grid container, and adds overlay elements for glow effects and shimmer animations. Icon effects like shimmer and luster are rendered per-frame using SkiaSharp at the icon's display resolution.
                    </TextBlock>

                    <TextBlock Text="Known Limitations" FontWeight="SemiBold" FontSize="13" Margin="0,5,0,5" Foreground="#FFD166"/>
                    <StackPanel Margin="10,0,0,15">
                        <TextBlock Text="• Effects are applied at display resolution (~48px), not source icon resolution. Subtle details may not be visible at this size."
                                   FontSize="11" Foreground="#CCC" TextWrapping="Wrap" Margin="0,0,0,6"/>
                        <TextBlock Text="• Visual tree injection depends on Playnite's internal element structure, which may vary between themes. Some themes may not expose icons in a compatible way."
                                   FontSize="11" Foreground="#CCC" TextWrapping="Wrap" Margin="0,0,0,6"/>
                        <TextBlock Text="• The Circular effect shape is a manual setting — auto-detection of icon shape is not possible through the visual tree."
                                   FontSize="11" Foreground="#CCC" TextWrapping="Wrap" Margin="0,0,0,6"/>
                        <TextBlock Text="• Shimmer and luster effects use SkiaSharp software rendering, which is CPU-based. On very large icon displays, this may impact performance."
                                   FontSize="11" Foreground="#CCC" TextWrapping="Wrap" Margin="0,0,0,6"/>
                        <TextBlock Text="• WPF's compositing model means overlay effects are alpha-blended over the original icon. This can slightly alter the icon's apparent colors during effect cycles."
                                   FontSize="11" Foreground="#CCC" TextWrapping="Wrap" Margin="0,0,0,6"/>
                    </StackPanel>

                    <TextBlock Text="Credits" FontWeight="SemiBold" FontSize="13" Margin="0,5,0,5"/>
                    <TextBlock Text="Built with SkiaSharp for rendering and Playnite SDK for integration."
                               FontSize="11" Foreground="#CCC" TextWrapping="Wrap" Margin="0,0,0,5"/>
                    <TextBlock Text="Metallic luster techniques inspired by simeydotme/pokemon-cards-css."
                               FontSize="11" Foreground="#CCC" TextWrapping="Wrap" Margin="0,0,0,15"/>

                    <TextBlock Text="Version 1.1.0" FontSize="10" Foreground="#666"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Preview Tab -->
        <TabItem Header="Preview">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,15,20,10">
                    <TextBlock Text="Glow Preview" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Shows how your current glow settings look on example game icons"
                               FontSize="11" Foreground="Gray" Margin="0,3,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" Margin="20,0,20,10"
                        CornerRadius="6" BorderThickness="1"
                        BorderBrush="#333344">
                    <Grid x:Name="PreviewContainer"
                          Background="#1A1A2E"/>
                </Border>

                <Button Grid.Row="2" Content="Refresh Preview"
                        Click="RefreshPreview_Click"
                        HorizontalAlignment="Center"
                        Padding="20,6" Margin="0,0,0,15" FontSize="12"/>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
